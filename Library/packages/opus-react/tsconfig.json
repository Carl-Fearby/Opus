{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "outDir": "./dist",
    "rootDir": "../..",
    "paths": {
      "@/*": ["../../*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "../../components/**/*.ts", "../../components/**/*.tsx", "../../lib/**/*.ts"],
  "exclude": ["../../app", "../../node_modules", "../../.next", "dist"]
}
